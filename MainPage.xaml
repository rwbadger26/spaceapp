<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:spaceapp.Models"
             xmlns:viewModels="clr-namespace:spaceapp.ViewModels"
             x:Class="spaceapp.MainPage"
             x:DataType="viewModels:NewsViewModel"
             Title="Space News"
             BackgroundColor="#05070F">

    <Grid Padding="10" BackgroundColor="#05070F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Label Grid.Row="0" 
               Text="Latest Space News" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="#F3F7FF" />

        <!-- News Cards (Always visible) -->
        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Articles}" 
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <!-- Keep your existing card template here -->
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Overlay (Only visible while loading) -->
        <Grid Grid.Row="1"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="#05070F"
              HorizontalOptions="FillAndExpand"
              VerticalOptions="FillAndExpand">

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               Color="#60A5FA"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Scale="2.0" />
        </Grid>

    </Grid>

</ContentPage>