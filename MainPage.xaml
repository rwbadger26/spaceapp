<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:spaceapp.Models"
             xmlns:viewModels="clr-namespace:spaceapp.ViewModels"
             x:Class="spaceapp.MainPage"
             x:DataType="viewModels:NewsViewModel"
             Title="Space News"
             BackgroundColor="#05070F">

    <Grid Padding="10" RowSpacing="10" BackgroundColor="#05070F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Label Grid.Row="0" 
               Text="Latest Space News" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="#F3F7FF" />

        <!-- News Cards -->
        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Articles}" 
                        SelectionMode="None"
                        VerticalOptions="FillAndExpand">
            <!-- ... your existing ItemTemplate stays the same ... -->
        </CollectionView>

        <!-- Loading Spinner (placed AFTER CollectionView so it's on top) -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#60A5FA"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Scale="1.5" />

    </Grid>

</ContentPage>